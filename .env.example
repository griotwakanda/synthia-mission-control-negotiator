# App
NODE_ENV=development
PORT=8080
SIMULATION_MODE=true

# Twilio (required for live calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=

# OpenAI (required for realtime voice conversation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Optional: webhook signing / internal auth
MISSION_CONTROL_API_TOKEN=
